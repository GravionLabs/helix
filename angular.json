{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "helix": {
      "projectType": "library",
      "root": "projects/helix",
      "sourceRoot": "projects/helix/src",
      "prefix": "helix",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/helix/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/helix/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/helix/tsconfig.spec.json"
          },
          "configurations": {
            "ci": {
              "coverage": true,
              "coverageReporters": ["cobertura"],
              "reporters": ["junit"],
              "outputFile": "test-results/junit.xml"
            }
          }
        }
      }
    },
    "helix-zod": {
      "projectType": "library",
      "root": "projects/helix-zod",
      "sourceRoot": "projects/helix-zod/src",
      "prefix": "helix-zod",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/helix-zod/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/helix-zod/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/helix-zod/tsconfig.spec.json"
          },
          "configurations": {
            "ci": {
              "coverage": true,
              "coverageReporters": ["cobertura"],
              "reporters": ["junit"],
              "outputFile": "test-results/junit.xml"
            }
          }
        }
      }
    },
    "helix-demo": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "apps/helix-demo",
      "sourceRoot": "apps/helix-demo/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "apps/helix-demo/src/main.ts",
            "tsConfig": "apps/helix-demo/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/helix-demo/public"
              }
            ],
            "styles": [
              "node_modules/primeicons/primeicons.css",
              "apps/helix-demo/src/styles.scss",
              "dist/helix/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "4MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "8kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "helix-demo:build:production"
            },
            "development": {
              "buildTarget": "helix-demo:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
