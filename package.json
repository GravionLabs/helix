{
  "name": "helix",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "pnpm build:lib:css && concurrently \"tailwindcss -i projects/helix/styles-src.css -o dist/helix/styles.css --watch\" \"ng serve helix-demo\"",
    "build": "pnpm build:lib && ng build helix-demo",
    "build:lib": "ng build helix && ng build helix-zod && pnpm build:lib:css",
    "build:lib:css": "tailwindcss -i projects/helix/styles-src.css -o dist/helix/styles.css --content \"projects/helix/src/**/*.{html,ts}\"",
    "build:demo": "ng build helix-demo",
    "watch": "ng build helix-demo --watch --configuration development",
    "test": "ng test",
    "test:lib": "ng test helix && ng test helix-zod",
    "test:lib:stable": "NODE_OPTIONS=--max-old-space-size=6144 ng test helix --watch=false --include=\"**/*.spec.ts\"",
    "test:ci": "ng test helix --configuration=ci",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check . && eslint \"projects/**/*.html\"",
    "lint:fix": "biome check --write . && eslint \"projects/**/*.html\" --fix",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/signals": "^21.0.1",
    "@primeuix/themes": "^2.0.3",
    "@tailwindcss/postcss": "^4.2.2",
    "chart.js": "^4.4.2",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/cli": "^4.3.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "ng-packagr": "^21.2.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.ts": [
      "biome check --write"
    ],
    "*.html": [
      "eslint --fix"
    ]
  }
}
