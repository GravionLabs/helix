{
  "name": "gravion-sakai",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "start:demo": "ng serve demo",
    "dev": "ng serve demo",
    "build": "ng build sakai-ui && ng build demo",
    "build:lib": "ng build sakai-ui",
    "build:demo": "ng build demo",
    "watch": "ng build demo --watch --configuration development",
    "test": "ng test",
    "test:lib": "ng test sakai-ui",
    "test:lib:stable": "NODE_OPTIONS=--max-old-space-size=6144 ng test sakai-ui --watch=false --include=\"**/*.spec.ts\"",
    "test:ci": "ng test sakai-ui --configuration=ci",
    "format": "prettier --write \"projects/**/*.{ts,html,scss}\"",
    "lint": "eslint \"projects/**/*.ts\" \"projects/**/*.html\"",
    "lint:fix": "eslint \"projects/**/*.ts\" \"projects/**/*.html\" --fix",
    "format:check": "prettier --check \"projects/**/*.{ts,html,scss}\"",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/signals": "^21.0.1",
    "@primeuix/themes": "^2.0.3",
    "@tailwindcss/postcss": "^4.2.2",
    "chart.js": "^4.4.2",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "projects/**/*.{ts,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "projects/**/*.scss": [
      "prettier --write"
    ]
  }
}
