{
  "name": "helix",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "demo:generate-sources": "node scripts/generate-source-assets.mjs",
    "start": "pnpm demo:generate-sources && pnpm build:lib:css && pnpm build:lib:css:ag-grid && concurrently \"tailwindcss -i projects/helix-shell/styles-src.css -o dist/helix-shell/styles.css --watch\" \"tailwindcss -i projects/helix-ag-grid/styles-src.css -o dist/helix-ag-grid/styles.css --watch\" \"ng serve helix-demo\"",
    "build": "pnpm demo:generate-sources && pnpm build:lib && ng build helix-demo",
    "build:lib": "ng build helix-shell && ng build helix-zod && ng build helix-ag-grid && pnpm build:lib:css && pnpm build:lib:css:ag-grid",
    "build:lib:css": "tailwindcss -i projects/helix-shell/styles-src.css -o dist/helix-shell/styles.css --content \"projects/helix-shell/src/**/*.{html,ts}\"",
    "build:lib:css:ag-grid": "tailwindcss -i projects/helix-ag-grid/styles-src.css -o dist/helix-ag-grid/styles.css",
    "build:demo": "pnpm demo:generate-sources && ng build helix-demo",
    "watch": "ng build helix-demo --watch --configuration development",
    "test": "ng test",
    "test:lib": "ng test helix-shell && ng test helix-zod && ng test helix-ag-grid",
    "test:lib:stable": "NODE_OPTIONS=--max-old-space-size=6144 ng test helix-shell --watch=false --include=\"**/*.spec.ts\"",
    "test:ci": "ng test helix-shell --configuration=ci",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check . && eslint \"projects/**/*.html\"",
    "lint:fix": "biome check --write . && eslint \"projects/**/*.html\" --fix",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/signals": "^21.0.1",
    "@primeuix/motion": "0.0.10",
    "@primeuix/styled": "0.7.4",
    "@primeuix/styles": "2.0.3",
    "@primeuix/themes": "2.0.3",
    "@primeuix/utils": "0.7.2",
    "@tailwindcss/postcss": "^4.2.2",
    "chart.js": "^4.4.2",
    "highlight.js": "^11.11.1",
    "ngx-highlightjs": "^14.0.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.3",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/cli": "^4.3.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.1",
    "ag-grid-angular": "^35.3.1",
    "ag-grid-community": "^35.3.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "ng-packagr": "^21.2.0",
    "quill": "2.0.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.ts": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.html": [
      "eslint --fix"
    ]
  }
}
